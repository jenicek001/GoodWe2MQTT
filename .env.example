# GoodWe2MQTT environment configuration
G2M_LOG_LEVEL=INFO

# MQTT Broker — point this at your existing broker.
# If using the bundled Mosquitto via docker-compose.mqtt.yml, keep localhost.
G2M_MQTT_BROKER_IP=127.0.0.1
G2M_MQTT_BROKER_PORT=1883
# G2M_MQTT_USERNAME=
# G2M_MQTT_PASSWORD=

# Inverter Configuration (required)
G2M_GOODWE_INVERTERS_0_IP_ADDRESS=192.168.1.100
G2M_GOODWE_INVERTERS_0_SERIAL_NUMBER=9010KETXXXXXXXXX

# Optional additional inverter(s)
# G2M_GOODWE_INVERTERS_1_IP_ADDRESS=192.168.1.101
# G2M_GOODWE_INVERTERS_1_SERIAL_NUMBER=98000ETXXXXXXXXX
