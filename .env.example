# GoodWe2MQTT environment configuration

# Logging (Docker default: console only via docker logs; set LOG_TO_FILE=true and mount /app/logs for persistent log files)
G2M_LOG_LEVEL=INFO
# G2M_LOG_TO_CONSOLE=true
# G2M_LOG_TO_FILE=false
# G2M_LOG_FILE=/app/logs/goodwe2mqtt.log

# MQTT Broker — point this at your existing broker.
# If using the bundled Mosquitto via docker-compose.mqtt.yml, keep localhost.
G2M_MQTT_BROKER_IP=127.0.0.1
G2M_MQTT_BROKER_PORT=1883
# G2M_MQTT_USERNAME=
# G2M_MQTT_PASSWORD=

# ET Inverter polling intervals
# G2M_MQTT_FAST_RUNTIME_DATA_INTERVAL_SECONDS=5   # how often inverter is polled and data published to .../fast_runtime_data (0 = disabled)
# G2M_MQTT_RUNTIME_DATA_INTERVAL_SECONDS=5        # how often data is also published to .../runtime_data

# Inverter Configuration (required)
G2M_GOODWE_INVERTERS_0_IP_ADDRESS=192.168.1.100
G2M_GOODWE_INVERTERS_0_SERIAL_NUMBER=9010KETXXXXXXXXX

# Optional additional inverter(s)
# G2M_GOODWE_INVERTERS_1_IP_ADDRESS=192.168.1.101
# G2M_GOODWE_INVERTERS_1_SERIAL_NUMBER=98000ETXXXXXXXXX

# ── SEC1000S Energy Controller ─────────────────────────────────────────────
# Add a GoodWe SEC1000S export-limit controller.  Multiple devices are
# supported by incrementing the index (0, 1, 2, …).
#
# Required fields:
#   G2M_SEC1000S_<N>_HOST                IP address of the SEC1000S
#   G2M_SEC1000S_<N>_SERIAL_NUMBER       Device serial number used in MQTT topics
#   G2M_SEC1000S_<N>_CONTRACTUAL_LIMIT_W Grid connection contractual limit (W)
#
# Optional fields (defaults shown):
#   G2M_SEC1000S_<N>_PORT=1234
#   G2M_SEC1000S_<N>_TIMEOUT=10.0
#   G2M_SEC1000S_<N>_MIN_LIMIT_W=100          # accepts negative values (e.g. -1000) to allow discharging into the grid
#   G2M_SEC1000S_<N>_CONTRACTUAL_SAFETY_MARGIN=0.10
#   G2M_SEC1000S_<N>_SCAN_THREE_PHASES=false
#   G2M_SEC1000S_<N>_TELEMETRY_INTERVAL_SECONDS=5
#   G2M_SEC1000S_<N>_GRID_EXPORT_LIMIT_INTERVAL_SECONDS=30
#   G2M_SEC1000S_<N>_SET_VERIFY_RETRIES=3
#   G2M_SEC1000S_<N>_SET_VERIFY_DELAY_SECONDS=2.0
#
# MQTT topics published:
#   goodwe2mqtt/sec1000s/<serial_number>/telemetry          — v1/v2/v3, i1/i2/i3, p*_watts, …
#   goodwe2mqtt/sec1000s/<serial_number>/grid_export_limit  — grid_export_limit_watts, ceiling, mode
#   goodwe2mqtt/sec1000s/<serial_number>/status             — "online"
#   goodwe2mqtt/sec1000s/<serial_number>/control            — send {"set_grid_export_limit_watts": 3000}
#
# Example:
# G2M_SEC1000S_0_HOST=192.168.1.200
# G2M_SEC1000S_0_SERIAL_NUMBER=home
# G2M_SEC1000S_0_CONTRACTUAL_LIMIT_W=10000
# G2M_SEC1000S_0_CONTRACTUAL_SAFETY_MARGIN=0.10
# G2M_SEC1000S_0_MIN_LIMIT_W=100
